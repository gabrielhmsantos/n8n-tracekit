# ================================
# Image
# ================================
IMAGE_REPO=gabrielhmsantos/n8n-tracekit
N8N_IMAGE_TAG=2.6.4
N8N_RUNNERS_TAG=2.6.4
N8N_PORT=5678

# ================================
# Hosts / URLs
# ================================
N8N_HOST=n8n.example.com
N8N_EDITOR_BASE_URL=https://n8n.example.com/
WEBHOOK_URL=https://webhook.example.com/
N8N_PROTOCOL=https

# ================================
# Environment / Locale
# ================================
NODE_ENV=production
GENERIC_TIMEZONE=UTC
TZ=UTC

# ================================
# Postgres (external)
# ================================
POSTGRES_HOST=postgres.example.com
POSTGRES_PORT=5432
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change_me

# ================================
# Redis (external)
# ================================
REDIS_HOST=redis.example.com
REDIS_PORT=6379
REDIS_DB=0

# ================================
# n8n encryption
# ================================
N8N_ENCRYPTION_KEY=change_me

# ================================
# External runners
# ================================
N8N_RUNNERS_AUTH_TOKEN=change_me
N8N_RUNNERS_MAX_CONCURRENCY=20
N8N_WORKER_CONCURRENCY=10

# ================================
# OpenTelemetry
# ================================
OTEL_SERVICE_NAME=n8n
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_EXPORTER_OTLP_ENDPOINT=https://otel-collector.example.com
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=https://tempo.example.com
OTEL_EXPORTER_OTLP_HEADERS=authorization=change_me
OTEL_LOGS_EXPORTER=none
OTEL_METRICS_EXPORTER=none
OTEL_LOG_LEVEL=INFO
TRACING_LOG_LEVEL=info

# ================================
# Tracing flags
# ================================
TRACING_WORKFLOW_ENABLED=false
TRACING_LLM_ENABLED=false
TRACING_LLM_DEBUG_EVENTS=false
TRACING_LLM_DEBUG_EXPORT=false

# ================================
# Langfuse (LLM tracing)
# ================================
LANGFUSE_PUBLIC_KEY=pk-lf-your_public_key
LANGFUSE_SECRET_KEY=sk-lf-your_secret_key
LANGFUSE_HOST=https://cloud.langfuse.com
